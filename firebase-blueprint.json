{
  "entities": {
    "visitor": {
      "title": "Visitante",
      "description": "Informações básicas de um visitante.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "cpf": { "type": "string" },
        "passport": { "type": "string" },
        "isForeigner": { "type": "boolean" },
        "gender": { "type": "string", "enum": ["masculino", "feminino"] },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "category": { "type": "string", "enum": ["general", "student", "researcher"] },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "isForeigner", "gender", "category"]
    },
    "locker": {
      "title": "Armário",
      "description": "Status e atribuição de um armário.",
      "type": "object",
      "properties": {
        "number": { "type": "integer" },
        "status": { "type": "string", "enum": ["available", "occupied", "maintenance"] },
        "visitorId": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["number", "status"]
    },
    "visit": {
      "title": "Visita",
      "description": "Registro de uma visita específica.",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "nome": { "type": "string" },
        "perfil": { "type": "string" },
        "local": { "type": "string" },
        "localId": { "type": "string" },
        "checkin": { "type": "string", "format": "date-time" },
        "checkout": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Ativo", "Concluído", "Excedido"] }
      },
      "required": ["visitorId", "nome", "perfil", "local", "checkin", "status"]
    },
    "usuario": {
      "title": "Usuário do Sistema",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "perfil": { "type": "string", "enum": ["administrador", "coordenador", "funcionario"] },
        "espacoId": { "type": "string" },
        "espacoNome": { "type": "string" },
        "ativo": { "type": "boolean" }
      }
    },
    "espaco": {
      "title": "Espaço Cultural",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "endereco": { "type": "string" },
        "totalArmarios": { "type": "number" },
        "ativo": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/visitors/{visitorId}": { "schema": "visitor" },
    "/lockers/{lockerId}": { "schema": "locker" },
    "/visits/{visitId}": { "schema": "visit" },
    "/espacos/{docId}": { "schema": "espaco" },
    "/usuarios/{userId}": { "schema": "usuario" },
    "/configuracoes/sistema": { "schema": "object" }
  }
}
