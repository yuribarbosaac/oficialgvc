rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'yuribarbosa18@gmail.com');
    }

    // Role checks - direct UID lookup since Firestore doc ID == Auth UID
    function getUserData(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'yuribarbosa18@gmail.com' || 
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
         getUserData(request.auth.uid).perfil == 'administrador')
      );
    }

    function isCoordinator() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
         getUserData(request.auth.uid).perfil == 'coordenador')
      );
    }

    // --- COLLECTIONS ---

    // 1. Visitors Collection
    match /visitors/{visitorId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(visitorId);
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // 2. Lockers Collection
    match /lockers/{lockerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 2.1 Computadores Collection
    match /computadores/{pcId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 2.2 Agendamentos Collection
    match /agendamentos/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isCoordinator();
      allow delete: if isAdmin();
    }

    // 3. Visits Collection
    match /visits/{visitId} {
      allow read, write: if isSignedIn();
    }

    // 4. Locations Collection (Legacy path)
    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 5. Usuarios Collection
    match /usuarios/{userId} {
      allow read, write: if isSignedIn();
    }

    // 6. Espacos Collection
    match /espacos/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 7. Configuracoes Collection (Legacy config)
    match /configuracoes/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 8. Auditoria Collection
    match /auditoria/{docId} {
      allow list: if isCoordinator();
      allow get: if isCoordinator();
      allow create: if isSignedIn();
      allow update, delete: if false; // Audit logs are immutable
    }
  }
}
